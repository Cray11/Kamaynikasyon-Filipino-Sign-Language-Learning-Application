<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Question Number -->
            <TextView
                android:id="@+id/tv_question_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp"
                android:text="Question 1"
                android:textColor="@color/primary_color"
                android:textSize="18sp"
                android:textStyle="bold" />

        <!-- Question Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <!-- Question Video -->
            <FrameLayout
                android:id="@+id/frame_layout_question_video"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">
                <androidx.media3.ui.PlayerView
                    android:id="@+id/video_view_question"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone"
                    app:use_controller="false" />
                <ImageButton
                    android:id="@+id/btn_menu_question_video"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_fullscreen"
                    android:contentDescription="Video options"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- Question Image -->
            <ImageView
                android:id="@+id/image_view_question"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                android:scaleType="centerCrop"
                android:contentDescription="Question image" />

            <!-- Question Text -->
            <TextView
                android:id="@+id/tv_question"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="What is the question?"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center" />

        </LinearLayout>

        <!-- Answer Options -->
        <LinearLayout
            android:id="@+id/answer_options_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <!-- Option 1 -->
            <LinearLayout
                android:id="@+id/option_1_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_answer_btn"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:id="@+id/frame_layout_option_1_video"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone">
                    <androidx.media3.ui.PlayerView
                        android:id="@+id/video_option_1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:visibility="gone"
                        app:use_controller="false" />
                    <ImageButton
                        android:id="@+id/btn_menu_video_option_1"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="4dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_fullscreen"
                        android:contentDescription="Video options"
                        android:visibility="gone" />
                </FrameLayout>

                <ImageView
                    android:id="@+id/image_option_1"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"
                    android:scaleType="centerCrop"
                    android:contentDescription="Option 1 image" />

                <TextView
                    android:id="@+id/text_option_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Option 1"
                    android:textSize="16sp"
                    android:textColor="@color/color_black"
                    android:gravity="center" />

            </LinearLayout>

            <!-- Option 2 -->
            <LinearLayout
                android:id="@+id/option_2_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_answer_btn"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:id="@+id/frame_layout_option_2_video"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone">
                    <androidx.media3.ui.PlayerView
                        android:id="@+id/video_option_2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:visibility="gone"
                        app:use_controller="false" />
                    <ImageButton
                        android:id="@+id/btn_menu_video_option_2"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="4dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_fullscreen"
                        android:contentDescription="Video options"
                        android:visibility="gone" />
                </FrameLayout>

                <ImageView
                    android:id="@+id/image_option_2"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"
                    android:scaleType="centerCrop"
                    android:contentDescription="Option 2 image" />

                <TextView
                    android:id="@+id/text_option_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Option 2"
                    android:textSize="16sp"
                    android:textColor="@color/color_black"
                    android:gravity="center" />

            </LinearLayout>

            <!-- Option 3 -->
            <LinearLayout
                android:id="@+id/option_3_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_answer_btn"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:id="@+id/frame_layout_option_3_video"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone">
                    <androidx.media3.ui.PlayerView
                        android:id="@+id/video_option_3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:visibility="gone"
                        app:use_controller="false" />
                    <ImageButton
                        android:id="@+id/btn_menu_video_option_3"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="4dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_fullscreen"
                        android:contentDescription="Video options"
                        android:visibility="gone" />
                </FrameLayout>

                <ImageView
                    android:id="@+id/image_option_3"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"
                    android:scaleType="centerCrop"
                    android:contentDescription="Option 3 image" />

                <TextView
                    android:id="@+id/text_option_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Option 3"
                    android:textSize="16sp"
                    android:textColor="@color/color_black"
                    android:gravity="center" />

            </LinearLayout>

            <!-- Option 4 -->
            <LinearLayout
                android:id="@+id/option_4_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_answer_btn"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:id="@+id/frame_layout_option_4_video"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone">
                    <androidx.media3.ui.PlayerView
                        android:id="@+id/video_option_4"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:visibility="gone"
                        app:use_controller="false" />
                    <ImageButton
                        android:id="@+id/btn_menu_video_option_4"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="4dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_fullscreen"
                        android:contentDescription="Video options"
                        android:visibility="gone" />
                </FrameLayout>

                <ImageView
                    android:id="@+id/image_option_4"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone"
                    android:scaleType="centerCrop"
                    android:contentDescription="Option 4 image" />

                <TextView
                    android:id="@+id/text_option_4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Option 4"
                    android:textSize="16sp"
                    android:textColor="@color/color_black"
                    android:gravity="center" />

            </LinearLayout>

        </LinearLayout>

        <!-- 2x2 Grid Layout for Multimedia Answers -->
        <LinearLayout
            android:id="@+id/grid_options_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp"
            android:visibility="gone">

            <!-- First Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Option 1 Grid -->
                <LinearLayout
                    android:id="@+id/grid_option_1_container"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_answer_btn"
                    android:padding="12dp"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:id="@+id/frame_layout_grid_option_1_video"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone">
                        <androidx.media3.ui.PlayerView
                            android:id="@+id/grid_video_option_1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone"
                            app:use_controller="false" />
                        <ImageButton
                            android:id="@+id/btn_menu_grid_video_option_1"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="4dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@drawable/ic_fullscreen"
                            android:contentDescription="Video options"
                            android:visibility="gone" />
                    </FrameLayout>

                    <ImageView
                        android:id="@+id/grid_image_option_1"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone"
                        android:scaleType="centerCrop"
                        android:contentDescription="Option 1 image" />

                    <TextView
                        android:id="@+id/grid_text_option_1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Option 1"
                        android:textSize="14sp"
                        android:textColor="@color/color_black"
                        android:gravity="center" />

                </LinearLayout>

                <!-- Option 2 Grid -->
                <LinearLayout
                    android:id="@+id/grid_option_2_container"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_answer_btn"
                    android:padding="12dp"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:id="@+id/frame_layout_grid_option_2_video"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone">
                        <androidx.media3.ui.PlayerView
                            android:id="@+id/grid_video_option_2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone"
                            app:use_controller="false" />
                        <ImageButton
                            android:id="@+id/btn_menu_grid_video_option_2"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="4dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@drawable/ic_fullscreen"
                            android:contentDescription="Video options"
                            android:visibility="gone" />
                    </FrameLayout>

                    <ImageView
                        android:id="@+id/grid_image_option_2"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone"
                        android:scaleType="centerCrop"
                        android:contentDescription="Option 2 image" />

                    <TextView
                        android:id="@+id/grid_text_option_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Option 2"
                        android:textSize="14sp"
                        android:textColor="@color/color_black"
                        android:gravity="center" />

                </LinearLayout>

            </LinearLayout>

            <!-- Second Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Option 3 Grid -->
                <LinearLayout
                    android:id="@+id/grid_option_3_container"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_answer_btn"
                    android:padding="12dp"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:id="@+id/frame_layout_grid_option_3_video"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone">
                        <androidx.media3.ui.PlayerView
                            android:id="@+id/grid_video_option_3"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone"
                            app:use_controller="false" />
                        <ImageButton
                            android:id="@+id/btn_menu_grid_video_option_3"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="4dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@drawable/ic_fullscreen"
                            android:contentDescription="Video options"
                            android:visibility="gone" />
                    </FrameLayout>

                    <ImageView
                        android:id="@+id/grid_image_option_3"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone"
                        android:scaleType="centerCrop"
                        android:contentDescription="Option 3 image" />

                    <TextView
                        android:id="@+id/grid_text_option_3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Option 3"
                        android:textSize="14sp"
                        android:textColor="@color/color_black"
                        android:gravity="center" />

                </LinearLayout>

                <!-- Option 4 Grid -->
                <LinearLayout
                    android:id="@+id/grid_option_4_container"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_answer_btn"
                    android:padding="12dp"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:id="@+id/frame_layout_grid_option_4_video"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone">
                        <androidx.media3.ui.PlayerView
                            android:id="@+id/grid_video_option_4"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone"
                            app:use_controller="false" />
                        <ImageButton
                            android:id="@+id/btn_menu_grid_video_option_4"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="4dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@drawable/ic_fullscreen"
                            android:contentDescription="Video options"
                            android:visibility="gone" />
                    </FrameLayout>

                    <ImageView
                        android:id="@+id/grid_image_option_4"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone"
                        android:scaleType="centerCrop"
                        android:contentDescription="Option 4 image" />

                    <TextView
                        android:id="@+id/grid_text_option_4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Option 4"
                        android:textSize="14sp"
                        android:textColor="@color/color_black"
                        android:gravity="center" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Continue Button - Hidden since answers auto-proceed -->
        <Button
            android:id="@+id/btn_continue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Continue"
            android:textSize="16sp"
            android:padding="16dp"
            android:layout_marginTop="24dp"
            android:visibility="gone"
            android:background="@drawable/bg_answer_btn"
            android:textColor="@color/color_black" />

        <!-- Status Text -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select an answer to continue"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginTop="16dp" />

    </LinearLayout>

</ScrollView>

