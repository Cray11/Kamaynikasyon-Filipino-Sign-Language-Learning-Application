<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Icon/Image -->
    <ImageView
        android:id="@+id/iv_tutorial_icon"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

    <!-- Title -->
    <TextView
        android:id="@+id/tv_tutorial_page_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tutorial Title"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <!-- Description -->
    <TextView
        android:id="@+id/tv_tutorial_page_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tutorial description goes here. This explains what this feature does and how to use it."
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:lineSpacingExtra="4dp" />

</LinearLayout>
