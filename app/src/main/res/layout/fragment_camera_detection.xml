<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="@drawable/camera_rounded_background"
        android:clipToOutline="true" />

    <!-- Overlay for drawing hand landmarks -->
    <com.example.kamaynikasyon.core.OverlayView
        android:id="@+id/overlay_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- In-camera flexible result/verification overlay (transparent black bg) -->
    <LinearLayout
        android:id="@+id/result_overlay_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/result_overlay_background"
        android:padding="16dp"
        android:layout_margin="16dp"
        android:visibility="visible">

        <TextView
            android:id="@+id/prediction_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:text=""
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#DDFFFFFF"
            android:text=""
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <ProgressBar
            android:id="@+id/progress_verification"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="0"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Container for camera controls (optional) -->
    <FrameLayout
        android:id="@+id/camera_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Topmost permission overlay container (text + button) -->
    <FrameLayout
        android:id="@+id/permission_overlay_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="#88000000">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <TextView
                android:id="@+id/permission_overlay_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Please allow the app to use your camera to start the preview.\nTap Allow when prompted."
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/permission_request_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Allow Camera"
                android:visibility="visible" />

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
