<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/dialog_rounded_background">

    <TextView
        android:id="@+id/sync_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Content Update Available"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/sync_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="New content is available on the server. Would you like to sync?"
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <CheckBox
        android:id="@+id/checkbox_dont_show_again"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Do not check for online changes, use offline assets only"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="8dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp" />

    <CheckBox
        android:id="@+id/checkbox_download_media"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Download all videos and media files (uses more storage and data)"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="16dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp"
        android:visibility="gone"
        android:id="@+id/sync_progress_container">

        <ProgressBar
            android:id="@+id/sync_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/primary_color" />

        <TextView
            android:id="@+id/sync_progress_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/sync_file_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:maxLines="1"
            android:ellipsize="middle" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_skip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/action_not_now"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:padding="12dp"
            android:layout_marginEnd="8dp"
            android:maxLines="1"
            android:singleLine="true"
            android:ellipsize="none"
            app:cornerRadius="8dp"
            android:backgroundTint="@android:color/transparent"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sync"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sync"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:padding="12dp"
            android:maxLines="1"
            android:singleLine="true"
            android:ellipsize="none"
            app:cornerRadius="8dp"
            android:backgroundTint="@color/correct_color" />

    </LinearLayout>

</LinearLayout>

