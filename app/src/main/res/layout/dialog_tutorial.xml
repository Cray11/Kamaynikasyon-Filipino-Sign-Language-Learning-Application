<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_rounded_background"
    android:paddingHorizontal="24dp"
    android:paddingVertical="12dp">

    <!-- Header Layout -->
    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Empty view for balance -->
        <View
            android:layout_width="32dp"
            android:layout_height="32dp" />

        <!-- Progress bar indicator -->
        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="16dp"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/primary_color"
            android:progressBackgroundTint="@color/gray_300" />

        <!-- Close button -->
        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            android:src="@drawable/ic_x"
            android:contentDescription="Close tutorial"
            app:tint="@color/black" />
    </LinearLayout>

    <!-- ViewPager2 for tutorial pages -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager_tutorial"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/header_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Title -->
    <TextView
        android:id="@+id/tv_tutorial_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Info"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/view_pager_tutorial"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Tutorial description -->
    <TextView
        android:id="@+id/tv_tutorial_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Learn sign language"
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_tutorial_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Checkbox for "Don't show again" -->
    <CheckBox
        android:id="@+id/checkbox_dont_show_again"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Don't show this again"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tv_tutorial_description"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/checkbox_dont_show_again"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btn_prev"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Previous"
            android:layout_marginEnd="8dp"
            android:backgroundTint="@color/gray_300"
            android:textColor="@color/text_primary"
            android:maxLines="1"
            android:singleLine="true"
            android:ellipsize="none"
            app:cornerRadius="24dp"/>

        <Button
            android:id="@+id/btn_next"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Next"
            android:layout_marginStart="8dp"
            android:backgroundTint="@color/primary_color"
            android:textColor="@color/white"
            android:maxLines="1"
            android:singleLine="true"
            android:ellipsize="none"
            app:cornerRadius="24dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
